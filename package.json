{
    "name":  "envision-esg-dashboard",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite --host 127.0.0.1 --port 5173",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "preview:static":  "node scripts/serve-dist.mjs",
