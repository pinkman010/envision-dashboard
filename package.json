                    "test:demo-dataset":  "node --experimental-strip-types --test tests/build-full-demo-dataset.test.mjs tests/demo-data-repository.test.mjs"
                },
    "dependencies":  {
                         "clsx":  "^2.1.1",
                         "echarts":  "^6.0.0",
